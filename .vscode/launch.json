{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Dev (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-hostname",
        "127.0.0.1",
        "--web-port=8080",
        "--dart-define=ENV=dev"
      ]
    },
    {
      "name": "Flutter Prod (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-hostname",
        "127.0.0.1",
        "--web-port=8080",
        "--dart-define=ENV=prod"
      ]
    },
    {
      "name": "Flutter Dev (Web Server - External)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "web-server",
        "--web-hostname",
        "0.0.0.0",
        "--web-port",
        "8080",
        "--dart-define=ENV=dev"
      ]
    }
  ]
}
